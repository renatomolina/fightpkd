---
import BaseLayout from '../layouts/BaseLayout.astro';
import drugs from '../data/drugs.json';
import therapies from '../data/therapies.json';

const recruitingCount = drugs.filter(d => d.status === 'recruiting').length;
const totalDrugs = drugs.length;
const completedTherapies = therapies.filter(t => t.status === 'completed').length;
const ongoingStudies = therapies.filter(t => t.status === 'in_progress').length;
const lastUpdated = 'May 21, 2026';
---

<BaseLayout title="Home" description="PKD Cure Tracker — Tracking the drug development pipeline and therapeutic research for Polycystic Kidney Disease patients.">
  <section class="relative">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-white to-accent-50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 pb-16">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
          Tracking the fight against
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-accent-600">
            Polycystic Kidney Disease
          </span>
        </h1>
        <p class="mt-6 text-lg text-gray-600 leading-relaxed">
          A comprehensive, up-to-date dashboard of drugs in clinical trials and therapeutic research for PKD/ADPKD patients. Knowledge is power in the fight against kidney disease.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/pipeline" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors shadow-sm">
            View Drug Pipeline
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a href="/therapies" class="inline-flex items-center px-6 py-3 bg-white text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors border border-gray-300 shadow-sm">
            Explore Therapies
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative -mt-10 z-10">
    <div class="mb-3 text-right">
      <span class="text-xs text-gray-400">Last updated: {lastUpdated}</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
      <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-cyan-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <div>
            <p class="text-2xl font-bold text-gray-900">{totalDrugs}</p>
            <p class="text-sm text-gray-500">Drugs in Pipeline</p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <p class="text-2xl font-bold text-gray-900">{recruitingCount}</p>
            <p class="text-sm text-gray-500">Currently Recruiting</p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <p class="text-2xl font-bold text-gray-900">{ongoingStudies}</p>
            <p class="text-sm text-gray-500">Studies In Progress</p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div>
            <p class="text-2xl font-bold text-gray-900">{completedTherapies}</p>
            <p class="text-sm text-gray-500">Therapy Studies Completed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="bg-gradient-to-br from-primary-50 to-primary-100/50 rounded-xl p-8 border border-primary-200">
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Drug Pipeline</h2>
        <p class="text-gray-600 mb-4">
          Track {totalDrugs} drugs in clinical trials for PKD — from early Phase 1 studies to large Phase 3 trials.
          See which trials are currently enrolling patients.
        </p>
        <a href="/pipeline" class="text-primary-600 hover:text-primary-700 font-medium text-sm inline-flex items-center gap-1">
          View all drugs
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="bg-gradient-to-br from-accent-50 to-accent-100/50 rounded-xl p-8 border border-accent-200">
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Keto Research</h2>
        <p class="text-gray-600 mb-4">
          Explore the emerging evidence for ketogenic interventions in PKD — from the KETO-ADPKD trial
          to KetoCitra supplements and preclinical evidence.
        </p>
        <a href="/keto" class="text-accent-600 hover:text-accent-700 font-medium text-sm inline-flex items-center gap-1">
          Read the research
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <div>
          <h3 class="font-medium text-amber-900">Disclaimer</h3>
          <p class="text-sm text-amber-800 mt-1">
            This website is for informational purposes only and does not constitute medical advice.
            Always consult your nephrologist or healthcare provider before making any treatment decisions.
            Clinical trial information is sourced from ClinicalTrials.gov and may not reflect the most current status.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
