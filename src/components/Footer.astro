---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-1">
        <p class="font-semibold text-white mb-4">PKD Cure Tracker</p>
        <p class="text-sm text-gray-400 leading-relaxed">
          Tracking every drug, trial, and breakthrough in the fight against Polycystic Kidney Disease. 100% free and ad-free.
        </p>
      </div>

      <div>
        <p class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-4">Research</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/pipeline" class="text-gray-400 hover:text-white transition-colors">Drug Pipeline</a></li>
          <li><a href="/keto" class="text-gray-400 hover:text-white transition-colors">Keto & PKD</a></li>
          <li><a href="/therapies" class="text-gray-400 hover:text-white transition-colors">Therapies</a></li>
          <li><a href="/trials" class="text-gray-400 hover:text-white transition-colors">Clinical Trials</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-4">For Patients</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/recruiting" class="text-gray-400 hover:text-white transition-colors">Recruiting Now</a></li>
          <li><a href="/phases" class="text-gray-400 hover:text-white transition-colors">Trial Phases Guide</a></li>
          <li><a href="/research" class="text-gray-400 hover:text-white transition-colors">Keto Research</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-4">About</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/about" class="text-gray-400 hover:text-white transition-colors">Our Mission</a></li>
          <li><a href="/about/renato" class="text-gray-400 hover:text-white transition-colors">Who's Behind This</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-xs text-gray-500">&copy; {year} PKD Cure Tracker. For informational purposes only — not medical advice.</p>
      <p class="text-xs text-gray-500">Data sourced from ClinicalTrials.gov and published research</p>
    </div>
  </div>
</footer>
