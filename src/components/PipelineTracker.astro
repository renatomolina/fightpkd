            {drug.name}
          </div>

          {/* Phase 1 */}
          <div class="px-2">
            <div class="relative h-5 flex items-center">
              {drug.phase > 1 ? (
                <div class="w-full flex items-center">
                  <div class="flex-1 h-2.5 rounded-l-full" style={`background: ${completedColor.fill}`}></div>
                  <div class="w-5 h-5 rounded-full flex items-center justify-center shrink-0 -ml-1" style={`background: ${completedColor.fill}`}>
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              ) : drug.phase === 1 ? (
                <div class="w-full flex items-center">
                  <div class="h-2.5 rounded-l-full" style={`width: ${fillWidth}; background: ${sBar.fill}`}></div>
                  <div class="w-5 h-5 rounded-full flex items-center justify-center shrink-0 -ml-1" style={`background: ${sBar.fill}`}>
                    {drug.status === 'recruiting' ? (
                      <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h-1V7z"/></svg>
                    ) : drug.status === 'not_yet_recruiting' ? (
                      <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                    ) : drug.status === 'enrolling_by_invitation' ? (
                      <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
                    ) : (
                      <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/></svg>
                    )}
                  </div>
                  <div class="flex-1 h-2.5 rounded-r-full" style={`background: ${sBar.bg}`}></div>
                </div>
              ) : (
                <div class="w-full h-1 bg-gray-100 rounded-full"></div>
              )}
            </div>
          </div>

          {/* Phase 2 */}
          <div class="px-2">
            <div class="relative h-5 flex items-center">
              {drug.phase > 2 ? (
                <div class="w-full flex items-center">
