---
interface Drug {
  name: string;
  phase: number;
  status: string;
}

interface Props {
  drugs: Drug[];
}

const { drugs } = Astro.props;

const sortedDrugs = [...drugs].sort((a, b) => {
  if (b.phase !== a.phase) return b.phase - a.phase;
  const statusOrder: Record<string, number> = { recruiting: 0, not_yet_recruiting: 1, enrolling_by_invitation: 2, active_not_recruiting: 3, completed: 4 };
  return (statusOrder[a.status] ?? 5) - (statusOrder[b.status] ?? 5);
});

const statusColors: Record<string, { badge: string }> = {
  recruiting: { badge: 'bg-emerald-100 text-emerald-800' },
  not_yet_recruiting: { badge: 'bg-amber-100 text-amber-800' },
  active_not_recruiting: { badge: 'bg-sky-100 text-sky-800' },
  enrolling_by_invitation: { badge: 'bg-violet-100 text-violet-800' },
  completed: { badge: 'bg-gray-100 text-gray-600' },
};

const phaseColors: Record<number, { bg: string; fill: string }> = {
  1: { bg: '#ccfbf1', fill: '#0d9488' },
  2: { bg: '#dbeafe', fill: '#2563eb' },
  3: { bg: '#ede9fe', fill: '#7c3aed' },
};

const completedColor = { bg: '#d1fae5', fill: '#10b981' };

const statusFillPercent: Record<string, string> = {
  recruiting: '65%',
  not_yet_recruiting: '25%',
  active_not_recruiting: '50%',
  enrolling_by_invitation: '35%',
  completed: '100%',
};

const statusBarColors: Record<string, { bg: string; fill: string }> = {
  recruiting: { bg: '#d1fae5', fill: '#10b981' },
  not_yet_recruiting: { bg: '#fef3c7', fill: '#f59e0b' },
  active_not_recruiting: { bg: '#e0f2fe', fill: '#0ea5e9' },
  enrolling_by_invitation: { bg: '#ede9fe', fill: '#8b5cf6' },
  completed: { bg: '#d1fae5', fill: '#10b981' },
};

function getStatusBar(status: string) {
  return statusBarColors[status] || statusBarColors.recruiting;
}

const statusLabels: Record<string, string> = {
  recruiting: 'Recruiting',
  not_yet_recruiting: 'Not Yet Recruiting',
  active_not_recruiting: 'Active',
  enrolling_by_invitation: 'By Invitation',
  completed: 'Completed',
};

const statusDotColors: Record<string, string> = {
  recruiting: '#10b981',
  not_yet_recruiting: '#f59e0b',
  active_not_recruiting: '#0ea5e9',
  enrolling_by_invitation: '#8b5cf6',
  completed: '#6b7280',
};

function getBadge(status: string) {
  return statusColors[status]?.badge || statusColors.completed.badge;
}

function getPhaseColor(phase: number) {
  return phaseColors[phase] || phaseColors[1];
}

const statusIcons: Record<string, string> = {
  recruiting: 'person',
  not_yet_recruiting: 'clock',
  active_not_recruiting: 'arrow',
  enrolling_by_invitation: 'mail',
  completed: 'check',
};
---

<div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-6 mb-8">
  <h2 class="text-lg font-semibold text-gray-900 mb-2">Pipeline Overview</h2>
  <p class="text-sm text-gray-500 mb-4 sm:mb-6">Each row shows a drug's progression through clinical trial phases</p>

  <!-- Desktop: swimlane view -->
  <div class="hidden md:block">
    <div class="grid grid-cols-[180px_1fr_1fr_1fr_130px] gap-0 mb-2 px-2">
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider">Drug</div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider text-center">Phase 1</div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider text-center">Phase 2</div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider text-center">Phase 3</div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider text-right">Status</div>
    </div>

    <div class="border-t border-gray-100 mb-1"></div>

    {sortedDrugs.map((drug) => {
      const fillWidth = statusFillPercent[drug.status] || '50%';
      const sBar = getStatusBar(drug.status);
      return (
        <div class="grid grid-cols-[180px_1fr_1fr_1fr_130px] gap-0 items-center py-2 px-2 hover:bg-gray-50 rounded-lg transition-colors">
