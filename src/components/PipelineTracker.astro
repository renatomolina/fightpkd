---
interface Drug {
  name: string;
  phase: number;
  status: string;
}

interface Props {
  drugs: Drug[];
}

const { drugs } = Astro.props;

const sortedDrugs = [...drugs].sort((a, b) => {
  if (b.phase !== a.phase) return b.phase - a.phase;
  const statusOrder: Record<string, number> = { recruiting: 0, not_yet_recruiting: 1, enrolling_by_invitation: 2, active_not_recruiting: 3, completed: 4 };
  return (statusOrder[a.status] ?? 5) - (statusOrder[b.status] ?? 5);
});

const statusColors: Record<string, { badge: string }> = {
  recruiting: { badge: 'bg-emerald-100 text-emerald-800' },
  not_yet_recruiting: { badge: 'bg-amber-100 text-amber-800' },
  active_not_recruiting: { badge: 'bg-sky-100 text-sky-800' },
  enrolling_by_invitation: { badge: 'bg-violet-100 text-violet-800' },
  completed: { badge: 'bg-gray-100 text-gray-600' },
};

const phaseColors: Record<number, { bg: string; fill: string; completed: string }> = {
  1: { bg: '#ccfbf1', fill: '#0d9488', completed: '#5eead4' },
  2: { bg: '#dbeafe', fill: '#2563eb', completed: '#93c5fd' },
  3: { bg: '#ede9fe', fill: '#7c3aed', completed: '#c4b5fd' },
};

const statusLabels: Record<string, string> = {
  recruiting: 'Recruiting',
  not_yet_recruiting: 'Not Yet Recruiting',
  active_not_recruiting: 'Active',
  enrolling_by_invitation: 'By Invitation',
  completed: 'Completed',
};

const statusDotColors: Record<string, string> = {
  recruiting: '#10b981',
  not_yet_recruiting: '#f59e0b',
  active_not_recruiting: '#0ea5e9',
  enrolling_by_invitation: '#8b5cf6',
  completed: '#6b7280',
};

function getBadge(status: string) {
  return statusColors[status]?.badge || statusColors.completed.badge;
}

function getPhaseColor(phase: number) {
  return phaseColors[phase] || phaseColors[1];
}
---

<div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-6 mb-8">
  <h2 class="text-lg font-semibold text-gray-900 mb-2">Pipeline Overview</h2>
  <p class="text-sm text-gray-500 mb-4 sm:mb-6">Each row shows a drug's progression through clinical trial phases</p>

  <!-- Desktop: swimlane view -->
  <div class="hidden md:block">
    <div class="grid grid-cols-[180px_1fr_1fr_1fr_130px] gap-0 mb-2 px-2">
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider">Drug</div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider text-center">Phase 1</div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider text-center">Phase 2</div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider text-center">Phase 3</div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider text-right">Status</div>
    </div>

    <div class="border-t border-gray-100 mb-1"></div>

    {sortedDrugs.map((drug) => {
      const p1 = getPhaseColor(1);
      const p2 = getPhaseColor(2);
      const p3 = getPhaseColor(3);
      const currentPhaseColor = getPhaseColor(drug.phase);
      return (
        <div class="grid grid-cols-[180px_1fr_1fr_1fr_130px] gap-0 items-center py-2 px-2 hover:bg-gray-50 rounded-lg transition-colors">
          <div class="font-medium text-sm text-gray-900 truncate pr-3" title={drug.name}>
            {drug.name}
          </div>

          {/* Phase 1 */}
          <div class="px-2">
            <div class="relative h-3 flex items-center">
              {drug.phase > 1 ? (
                <div class="w-full h-2 rounded-full" style={`background: ${p1.completed}`}></div>
              ) : drug.phase === 1 ? (
                <div class="w-full h-2.5 rounded-full" style={`background: ${p1.bg}`}>
                  <div class="h-full rounded-full" style={`width: 65%; background: ${p1.fill}`}></div>
                </div>
              ) : (
                <div class="w-full h-1 bg-gray-100 rounded-full"></div>
              )}
            </div>
          </div>

          {/* Phase 2 */}
          <div class="px-2">
            <div class="relative h-3 flex items-center">
              {drug.phase > 2 ? (
                <div class="w-full h-2 rounded-full" style={`background: ${p2.completed}`}></div>
              ) : drug.phase === 2 ? (
                <div class="w-full h-2.5 rounded-full" style={`background: ${p2.bg}`}>
                  <div class="h-full rounded-full" style={`width: 65%; background: ${p2.fill}`}></div>
                </div>
              ) : (
                <div class="w-full h-1 bg-gray-100 rounded-full"></div>
              )}
            </div>
          </div>

          {/* Phase 3 */}
          <div class="px-2">
            <div class="relative h-3 flex items-center">
              {drug.phase > 3 ? (
                <div class="w-full h-2 rounded-full" style={`background: ${p3.completed}`}></div>
              ) : drug.phase === 3 ? (
                <div class="w-full h-2.5 rounded-full" style={`background: ${p3.bg}`}>
                  <div class="h-full rounded-full" style={`width: 65%; background: ${p3.fill}`}></div>
                </div>
              ) : (
                <div class="w-full h-1 bg-gray-100 rounded-full"></div>
              )}
            </div>
          </div>

          {/* Status */}
          <div class="flex justify-end">
            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${getBadge(drug.status)}`}>
              {drug.status === 'recruiting' && <span class="w-1.5 h-1.5 rounded-full mr-1 animate-pulse" style={`background: ${statusDotColors[drug.status]}`}></span>}
              {statusLabels[drug.status] || drug.status}
            </span>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Mobile: compact vertical list -->
  <div class="md:hidden space-y-2">
    {sortedDrugs.map((drug) => {
      const p1 = getPhaseColor(1);
      const p2 = getPhaseColor(2);
      const p3 = getPhaseColor(3);
      return (
        <div class="flex items-center gap-3 py-2 px-2 rounded-lg hover:bg-gray-50 transition-colors">
          {/* Phase dots */}
          <div class="flex items-center gap-1 shrink-0">
            <div class="w-3 h-3 rounded-full border-2" style={`${drug.phase >= 1 ? `background: ${drug.phase === 1 ? p1.fill : p1.completed}; border-color: ${drug.phase === 1 ? p1.fill : p1.completed}` : 'background: white; border-color: #e5e7eb'}`}></div>
            <div class="w-2 h-0.5 rounded-full" style={`background: ${drug.phase >= 2 ? p1.completed : '#e5e7eb'}`}></div>
            <div class="w-3 h-3 rounded-full border-2" style={`${drug.phase >= 2 ? `background: ${drug.phase === 2 ? p2.fill : p2.completed}; border-color: ${drug.phase === 2 ? p2.fill : p2.completed}` : 'background: white; border-color: #e5e7eb'}`}></div>
            <div class="w-2 h-0.5 rounded-full" style={`background: ${drug.phase >= 3 ? p2.completed : '#e5e7eb'}`}></div>
            <div class="w-3 h-3 rounded-full border-2" style={`${drug.phase >= 3 ? `background: ${drug.phase === 3 ? p3.fill : p3.completed}; border-color: ${drug.phase === 3 ? p3.fill : p3.completed}` : 'background: white; border-color: #e5e7eb'}`}></div>
          </div>

          {/* Drug name */}
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 truncate">{drug.name}</p>
          </div>

          {/* Status badge */}
          <span class={`shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${getBadge(drug.status)}`}>
            {drug.status === 'recruiting' && <span class="w-1.5 h-1.5 rounded-full mr-1 animate-pulse" style={`background: ${statusDotColors[drug.status]}`}></span>}
            {statusLabels[drug.status] || drug.status}
          </span>
        </div>
      );
    })}

    {/* Mobile phase legend */}
    <div class="pt-2 border-t border-gray-100 flex items-center gap-3 text-xs text-gray-400">
      <div class="flex items-center gap-0.5">
        <div class="w-2.5 h-2.5 rounded-full" style="background: #0d9488"></div>
        <span>P1</span>
      </div>
      <div class="flex items-center gap-0.5">
        <div class="w-2.5 h-2.5 rounded-full" style="background: #2563eb"></div>
        <span>P2</span>
      </div>
      <div class="flex items-center gap-0.5">
        <div class="w-2.5 h-2.5 rounded-full" style="background: #7c3aed"></div>
        <span>P3</span>
      </div>
      <span class="ml-1">colored = current phase</span>
    </div>
  </div>

  <!-- Desktop legend -->
  <div class="hidden md:flex mt-4 pt-4 border-t border-gray-100 flex-wrap items-center gap-5 text-xs text-gray-500">
    <span class="font-medium text-gray-600">Phases:</span>
    <div class="flex items-center gap-1.5">
      <div class="w-8 h-2.5 rounded-full" style="background: #0d9488"></div>
      <span>Phase 1</span>
    </div>
    <div class="flex items-center gap-1.5">
      <div class="w-8 h-2.5 rounded-full" style="background: #2563eb"></div>
      <span>Phase 2</span>
    </div>
    <div class="flex items-center gap-1.5">
      <div class="w-8 h-2.5 rounded-full" style="background: #7c3aed"></div>
      <span>Phase 3</span>
    </div>
    <span class="text-gray-300">|</span>
    <div class="flex items-center gap-1.5">
      <div class="w-8 h-2 rounded-full" style="background: #5eead4"></div>
      <span>Completed</span>
    </div>
    <div class="flex items-center gap-1.5">
      <div class="w-8 h-1 bg-gray-100 rounded-full"></div>
      <span>Upcoming</span>
    </div>
  </div>
</div>
